# Example environment file for systemd EnvironmentFile=
REPROXY_LISTEN_ADDR=:8080
REPROXY_STORAGE_PATH=/opt/reproxy/data/routes.json
REPROXY_NGINX_CONFIG_PATH=/etc/nginx/conf.d/reproxy.conf
REPROXY_ACME_WEBROOT=/var/www/reproxy-acme
REPROXY_CERTS_DIR=/etc/letsencrypt/live
# Must be a real mailbox accepted by your ACME provider when automatic TLS is enabled.
REPROXY_ADMIN_EMAIL=admin@your-real-domain.tld
REPROXY_CERT_PROVIDER=cloudflare
REPROXY_CLOUDFLARE_API_TOKEN=replace-with-your-cloudflare-token
REPROXY_CLOUDFLARE_CREDENTIALS_PATH=/etc/letsencrypt/cloudflare.ini
# Leave REPROXY_CERT_COMMAND_TEMPLATE unset when REPROXY_CERT_PROVIDER=cloudflare.
# Install the Certbot Cloudflare plugin package before enabling Cloudflare mode.
# If you prefer generic ACME tooling instead of the built-in Cloudflare path,
# unset REPROXY_CERT_PROVIDER and provide a custom command template:
# REPROXY_CERT_COMMAND_TEMPLATE='certbot certonly --webroot -w {{.Webroot}} -d {{.Domain}} --email {{.Email}} --agree-tos --non-interactive'
REPROXY_VALIDATE_COMMAND='nginx -t'
REPROXY_RELOAD_COMMAND='systemctl reload nginx'
